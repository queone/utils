# Build artifacts
*.out
*.test
*.exe

# Root command binaries (Go compiler emits these to repo root when `go build ./cmd/<name>` is run without -o).
/build
/prep
/rel

# Coverage
build-cover-*.out

# OS files
.DS_Store
Thumbs.db

# Governa working artifacts
.governa/sync-review.md
.governa/proposed/

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/

# ---- Go ----
# Go-specific additions appended by governa sync when stack:Go is detected.
# Based on the standard Go .gitignore; overlaps with the base are omitted.

# Binaries for plugins and cross-platform builds
*.exe~
*.dll
*.so
*.dylib

# Go workspace files
go.work
go.work.sum

# Environment file (conventionally untracked for Go services)
.env
